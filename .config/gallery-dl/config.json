{
    "extractor":{
        "base-directory": "$HOME/media",
        
        "4chan":{
            "directory":["gallery-dl", "4chan-{board}-{thread}-{title}"],
            "filename":"{no}-{filename}.{extension}"
        },

        "flickr":{
            "directory":["gallery-dl", "flickr-{owner['path_alias']}"],
            "filename":"{id}-{filename}.{extension}"
        },

        "instagram":{
            "directory":["gallery-dl", "ig-{username}"],
            "filename":"{shortcode}-{filename}.{extension}"
        }
    }
}
